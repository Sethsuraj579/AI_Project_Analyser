# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1

# Database
# Use PostgreSQL in production. Example:
# postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis (used by Celery and cache-backed security throttling)
# Example local Redis:
# redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Sentry
SENTRY_DSN=

# CORS
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000,http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-backend-domain.com/accounts/google/callback/

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=AI Project Analyser <noreply@your-domain.com>

# Celery
REQUIRE_CELERY_FOR_HEAVY_TASKS=True
