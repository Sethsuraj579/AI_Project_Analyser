# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis
REDIS_URL=rediss://default:password@host:6379

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# CORS (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Razorpay Payment Integration
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here

# Email Configuration (SMTP for sending emails)
# For Gmail: Use your email and an App Password (not your regular password)
# To get Gmail App Password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=AI Project Analyser <your_email@gmail.com>
